{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://drift-api-prod.up.railway.app"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://drift-api-prod.up.railway.app/api/:path*"
    }
  ]
}
