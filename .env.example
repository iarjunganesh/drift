# Copy to .env and fill in. Never commit .env.
# Use the API key from the "drift" project on platform.openai.com —
# not the key from bankers-wrapped or any other project.

OPENAI_API_KEY=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drift
SOURCES_CONFIG_PATH=backend/sources.yaml
DRIFT_MODE=fixture
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# Live-model safeguard. Keep these at or below the project-wide $10 limit.
DRIFT_MAX_SPEND_USD=10
DRIFT_SPEND_ALERT_USD=5
DRIFT_MAX_CALL_USD=1
