# Copy to .env and fill in. Never commit .env.
# Use the API key from the "drift" project on platform.openai.com —
# never reuse a key from another project.

OPENAI_API_KEY=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drift
# Optional local-notebook override for a Railway public TCP proxy. Keep
# DATABASE_URL as Railway's complete private service URL so credentials/database
# name remain private; these two values replace only its host and port locally.
# DRIFT_DATABASE_PUBLIC_HOST=tokaido.proxy.rlwy.net
# DRIFT_DATABASE_PUBLIC_PORT=43102
SOURCES_CONFIG_PATH=backend/sources.yaml
DRIFT_MODE=fixture
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# Live-model safeguard. Keep these at or below the project-wide $10 limit.
DRIFT_MAX_SPEND_USD=10
DRIFT_SPEND_ALERT_USD=5
DRIFT_MAX_CALL_USD=1

# Live-model resilience. The API uses a bounded bulkhead, timeout, retries,
# and a circuit breaker; these values are conservative local defaults.
DRIFT_MODEL_TIMEOUT_SECONDS=20
DRIFT_MODEL_QUEUE_TIMEOUT_SECONDS=2
DRIFT_MODEL_MAX_ATTEMPTS=3
DRIFT_MODEL_RETRY_BASE_SECONDS=0.25
DRIFT_MODEL_RETRY_MAX_SECONDS=2
DRIFT_MODEL_CIRCUIT_FAILURE_THRESHOLD=3
DRIFT_MODEL_CIRCUIT_RESET_SECONDS=30
DRIFT_MODEL_MAX_CONCURRENCY=2

# Primary release-feed ingestion. These bounds apply to each configured source.
DRIFT_SCOUT_TIMEOUT_SECONDS=15
DRIFT_SCOUT_MAX_ATTEMPTS=3
DRIFT_SCOUT_RETRY_BASE_SECONDS=0.5
DRIFT_SCOUT_RETRY_MAX_SECONDS=4
